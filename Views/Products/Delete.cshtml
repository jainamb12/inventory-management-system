@model WebApplication1.Models.Product

@{
    ViewData["Title"] = "Delete";
}


<div class="container mt-4">

    <div class="card shadow-sm border-0 col-md-6">

        <div class="card-header bg-danger text-white">
            Confirm Delete
        </div>

        <div class="card-body">

            <p class="text-muted">
                Are you sure you want to delete this product?
            </p>

            <ul class="list-group mb-3">
                <li class="list-group-item"><b>Name:</b> @Model.Name</li>
                <li class="list-group-item"><b>Category:</b> @Model.Category</li>
                <li class="list-group-item"><b>Price:</b> @Model.Price</li>
                <li class="list-group-item"><b>Quantity:</b> @Model.Quantity</li>
            </ul>

            <form asp-action="Delete">

                <input type="hidden" asp-for="Id" />

                <button type="submit" class="btn btn-danger">
                    Delete Product
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                    Cancel
                </a>

            </form>

        </div>

    </div>

</div>
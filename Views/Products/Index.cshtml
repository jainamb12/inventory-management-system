<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="page-title">Inventory Management</h2>

        <a asp-action="Create" class="btn btn-primary">
            + Add Product
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <form asp-action="Index" method="get">
                <div class="input-group shadow-sm">
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search by name, category, or supplier..." />
                    <button type="submit" class="btn btn-dark">🔍 Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">

        <div class="card-body p-0">

            <table class="table table-hover mb-0">

                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Supplier</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr class="align-middle">

                            <td class="fw-semibold">@item.Name</td>

                            <td>
                                <span class="badge bg-light text-dark">
                                    @(item.Category?.Name ?? "N/A")
                                </span>
                            </td>

                            <td>
                                <span class="badge bg-info text-dark">
                                    @(item.Supplier?.Name ?? "N/A")
                                </span>
                            </td>

                            <td>$@item.Price</td>

                            <td>

                                @if (item.Quantity <= 5)
                                {
                                    <span class="badge bg-danger">
                                        Low Stock (@item.Quantity)
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        In Stock (@item.Quantity)
                                    </span>
                                }

                            </td>

                            <td class="text-center">

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Edit
                                </a>

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-info">
                                    View
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-danger">
                                    Delete
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Inventory Page Navigation" class="mt-4">
        <ul class="pagination justify-content-center">

            <li class="page-item @(ViewBag.PageIndex == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(ViewBag.PageIndex - 1)" asp-route-searchString="@ViewData["CurrentFilter"]">Previous</a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.PageIndex ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-searchString="@ViewData["CurrentFilter"]">@i</a>
                </li>
            }

            <li class="page-item @(ViewBag.PageIndex == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(ViewBag.PageIndex + 1)" asp-route-searchString="@ViewData["CurrentFilter"]">Next</a>
            </li>

        </ul>
    </nav>
}
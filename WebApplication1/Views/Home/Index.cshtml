<div class="container mt-4">

    <div class="mb-4">
        <h2 class="page-title">System Dashboard</h2>
        <p class="text-muted">Real-time overview of your enterprise inventory</p>
    </div>

    <div class="row g-4 mb-4">

        <div class="col-md-3">
            <div class="card dashboard-card bg-white shadow-sm border-0">
                <div class="card-body text-center">
                    <h6 class="text-muted">Total Products</h6>
                    <h2 class="fw-bold text-primary">@ViewBag.TotalProducts</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card dashboard-card bg-white shadow-sm border-0">
                <div class="card-body text-center">
                    <h6 class="text-muted">Inventory Value</h6>
                    <h2 class="fw-bold text-success">$@ViewBag.InventoryValue.ToString("N2")</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card dashboard-card bg-white shadow-sm border-0">
                <div class="card-body text-center">
                    <h6 class="text-muted">Low Stock Alerts</h6>
                    <h2 class="fw-bold text-danger">@ViewBag.LowStockCount</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card dashboard-card bg-white shadow-sm border-0">
                <div class="card-body text-center">
                    <h6 class="text-muted">Suppliers</h6>
                    <h2 class="fw-bold text-dark">@ViewBag.TotalSuppliers</h2>
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white fw-bold">
            Critical Stock Alerts
        </div>

        <div class="card-body p-0">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Category</th>
                        <th>Quantity</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                All stock levels are healthy
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="align-middle">

                                <td class="fw-semibold">@item.Name</td>

                                <td>
                                    <span class="badge bg-light text-dark">
                                        @(item.Category?.Name ?? "N/A")
                                    </span>
                                </td>

                                <td>
                                    <span class="badge bg-danger">
                                        @item.Quantity Left
                                    </span>
                                </td>

                                <td>
                                    <a asp-controller="Products"
                                       asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-primary">
                                        Update
                                    </a>
                                </td>

                            </tr>
                        }
                    }

                </tbody>
            </table>
        </div>

    </div>

</div>
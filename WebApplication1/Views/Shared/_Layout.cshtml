<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartInventory</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

</head>

<body class="bg-light">

    <div class="d-flex">

        <!-- SIDEBAR -->
        <nav class="bg-dark text-white p-3 vh-100" style="width:260px;">

            <h4 class="mb-4">
                <a asp-controller="Home"
                   asp-action="Index"
                   class="text-white text-decoration-none fw-bold">
                    📦 SmartInventory
                </a>
            </h4>

            <ul class="nav flex-column">

                <li class="nav-item mb-2">
                    <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active-menu" : "")"
                       asp-controller="Products"
                       asp-action="Index">
                        <i class="bi bi-box-seam"></i>
                        Inventory
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active-menu" : "")"
                       asp-controller="Categories"
                       asp-action="Index">
                        <i class="bi bi-folder"></i>
                        Categories
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Suppliers" ? "active-menu" : "")"
                       asp-controller="Suppliers"
                       asp-action="Index">
                        <i class="bi bi-truck"></i>
                        Suppliers
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "StockTransactions" ? "active-menu" : "")"
                       asp-controller="StockTransactions"
                       asp-action="Index">
                        <i class="bi bi-journal-text"></i>
                        Audit Ledger
                    </a>
                </li>

            </ul>

        </nav>


        <!-- MAIN AREA -->
        <div class="flex-grow-1">

            <!-- TOP NAVBAR -->
            <nav class="navbar navbar-light bg-white border-bottom px-4">

                <div class="container-fluid">

                    <span class="navbar-brand fw-semibold">
                        @ViewData["Title"]
                    </span>

                    <div class="d-flex align-items-center">

                        <partial name="_LoginPartial" />

                    </div>

                </div>

            </nav>


            <!-- PAGE CONTENT -->
            <div class="container-fluid p-4">

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success shadow-sm">
                        @TempData["SuccessMessage"]
                    </div>
                }

                @RenderBody()

            </div>

        </div>

    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
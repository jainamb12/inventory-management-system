@model WebApplication1.Models.StockTransaction

@{
    ViewData["Title"] = "Record Transaction";
}

<div class="card shadow-sm border-0 col-lg-6">

    ```
    <div class="card-header bg-white fw-semibold">
        Record Manual Stock Movement
    </div>

    <div class="card-body">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">

                <label asp-for="ProductId" class="form-label fw-semibold">
                    Select Product
                </label>

                <select asp-for="ProductId"
                        class="form-select"
                        asp-items="ViewBag.ProductId">
                </select>

            </div>


            <div class="mb-3">

                <label asp-for="TransactionType" class="form-label fw-semibold">
                    Movement Type
                </label>

                <select asp-for="TransactionType" class="form-select">

                    <option value="">Select Type</option>
                    <option value="IN">IN (Restock / Purchase)</option>
                    <option value="OUT">OUT (Sale / Loss)</option>

                </select>

                <span asp-validation-for="TransactionType" class="text-danger"></span>

            </div>


            <div class="mb-3">

                <label asp-for="Quantity" class="form-label fw-semibold">
                    Quantity
                </label>

                <input asp-for="Quantity"
                       class="form-control"
                       type="number"
                       min="1" />

                <span asp-validation-for="Quantity" class="text-danger"></span>

            </div>


            <button type="submit" class="btn btn-success">
                Save Record
            </button>

            <a asp-action="Index"
               class="btn btn-outline-secondary ms-2">
                Back to Ledger
            </a>

        </form>

    </div>
    ```

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
